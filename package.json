{
    "name": "@woby/simple-router",
    "repository": "github:wobyjs/simple-router",
    "description": "A simple isomorphic router for Voby.",
    "version": "1.4.17",
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "main": "./dist/index.es.js",
    "module": "./dist/index.es.js",
    "types": "./dist/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/index.es.js",
            "require": "./dist/index.cjs.js"
        }
    },
    "sideEffects": false,
    "scripts": {
        "//clean": "tsex clean",
        "//compile": "tsex compile",
        "//compile:watch": "tsex compile --watch",
        "//prepublishOnly": "tsex prepare",
        "bump": "pnpm version patch --no-git-tag-version",
        "push": "git push && git push --tags",
        "npmjs": "pnpm publish --access public",
        "commit": "pnpm git && pnpm bump && pnpm push",
        "release": "run-s -c commit npmjs",
        "css:watch": "tailwindcss -i ./src/input.css -o ./dist/output.css --watch",
        "css11": "tailwindcss -i ./src/input.css -o ./dist/output.css",
        "declaration": "tsc --build --force --declaration --emitDeclarationOnly --declarationMap  --verbose",
        "declaration:watch": "tsc --build --force --declaration --emitDeclarationOnly --declarationMap  --verbose --watch",
        "watch": "run-p build:watch declaration:watch",
        "build": "run-s build:vite declaration && pnpm bump",
        "build:web": "vite build --config=vite.config.web.mts --force --mode production",
        "web": "vite preview --config=vite.config.web.mts --host",
        "dev:only": "vite --config=vite.config.web.mts --force --mode dev --host",
        "dev": "run-p dev:only",
        "build:vite": "vite build",
        "build:watch": "vite build --watch",
        "preview": "vite preview --host",
        "test": "playwright test",
        "test:ui": "playwright test --ui"
    },
    "keywords": [
        "woby",
        "router",
        "simple",
        "tiny",
        "isomorphic"
    ],
    "dependencies": {
        "@tailwindcss/postcss": "^4.2.1",
        "autoprefixer": "^10.4.27",
        "noren": "^0.4.7",
        "postcss": "^8.5.8",
        "tailwindcss": "^4.2.1"
    },
    "peerDependencies": {
        "woby": "workspace:../woby"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@types/node": "^25.5.0",
        "tsex": "^4.0.2",
        "typescript": "^5.9.3",
        "vite": "^6.4.1"
    }
}
